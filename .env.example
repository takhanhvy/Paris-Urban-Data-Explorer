# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=urban_data
POSTGRES_USER=ude_user
POSTGRES_PASSWORD=changeme

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=urban_data_nosql

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_AIRPARIF=airparif.quality

# ─── API Airparif ─────────────────────────────────────────────────────────────
AIRPARIF_API_KEY=your-api-key-here
AIRPARIF_BASE_URL=https://api.airparif.fr/indices/prevision/commune

# ─── API Logements sociaux ────────────────────────────────────────────────────
PARIS_OPENDATA_URL=https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/logements-sociaux-finances-a-paris/records

# ─── API interne FastAPI ──────────────────────────────────────────────────────
API_KEY=changeme-api-key
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ─── Chemins données ─────────────────────────────────────────────────────────
DATA_RAW_PATH=data/raw
DATA_BRONZE_PATH=data/bronze
DATA_SILVER_PATH=data/silver
DATA_GOLD_PATH=data/gold
